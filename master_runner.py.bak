import os
import time
from datetime import datetime
from core.logger import logger
# =========================
# AUTONOMOUS SYSTEM LOOP
# =========================

while True:

        try:
        logger.info("system_cycle_started")

        cycle_start = time.time()

        # =========================
        # HEADER
        # =========================
         

         

        
        
        

        print("\n")
        print("=" * 60)

        print(
            "🚀 AUTONOMOUS QUANT SYSTEM"
        )

        print("=" * 60)

        print("\n")

        print(
            f"🕒 Cycle Start: "
            f"{datetime.now()}"
        )

        # =========================
        # LOAD MARKET REGIME
        # =========================

        market_regime = "NEUTRAL"

        if os.path.exists(
            "market_regime.txt"
        ):

            with open(
                "market_regime.txt",
                "r"
            ) as f:

                market_regime = (
                    f.read().strip()
                )

        print("\n")

        print(
            f"🧠 Market Regime: "
            f"{market_regime}"
        )

        # =========================
        # REGIME MODE
        # =========================

        if market_regime == "DEFENSIVE":

            print(
                "🛡️ Defensive mode enabled"
            )

        elif market_regime == "AGGRESSIVE":

            print(
                "⚔️ Aggressive mode enabled"
            )

        else:

            print(
                "⚖️ Neutral mode enabled"
            )

        # =========================
        # SAFE ORCHESTRATION
        # =========================

        print("\n")

        print(
            "🛡️ Running safe runner..."
        )

        exit_code = os.system(
            "python safe_runner.py"
        )

        # =========================
        # SAFE RUNNER STATUS
        # =========================

        print("\n")

        print(
            f"🧾 Safe Runner Exit Code: "
            f"{exit_code}"
        )

        # =========================
        # CYCLE COMPLETE
        # =========================

        cycle_end = time.time()

        cycle_duration = round(

            cycle_end -

            cycle_start,

            2
        )

        print("\n")

        print(
            "✅ SYSTEM CYCLE COMPLETE"
        )

        print("\n")

        print(
            f"⏱️ Cycle Duration: "
            f"{cycle_duration}s"
        )

        print("\n")

        print(
            "⏳ Sleeping 60 seconds..."
        )

        # =========================
        # SLEEP
        # =========================
logger.info("system_cycle_completed")
        time.sleep(60)

    # =========================
    # GLOBAL EXCEPTION HANDLER
    # =========================

    except Exception as e:

        print("\n")
        print("=" * 60)

        print(
            "🚨 MASTER LOOP ERROR"
        )

        print("\n")

        print(str(e))

        print("\n")

        print(
            "🛡️ System survived exception"
        )

        print(
            "⏳ Restarting cycle in 60 seconds..."
        )

        time.sleep(60)
